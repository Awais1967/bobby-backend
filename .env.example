NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://127.0.0.1:27017/trivia-goat

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=
EMAIL_USER=
EMAIL_PASSWORD=

PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=15
# Development only: return the OTP in the forgot/resend response for local runtime testing.
PASSWORD_RESET_EXPOSE_OTP=false

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_PUBLIC_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=


SUPER_ADMIN_NAME=Trivia Goat Super Admin
SUPER_ADMIN_EMAIL=admin@triviagoat.com
SUPER_ADMIN_PASSWORD=change-this-password
